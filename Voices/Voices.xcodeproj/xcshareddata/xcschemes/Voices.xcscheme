      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      shouldUseLaunchSchemeArgsEnv = "NO"
      codeCoverageEnabled = "NO">
      <EnvironmentVariables>
         <!-- Required workaround for Firebase 11.x + Xcode 26 SPM bug.
              Forces Firestore + gRPC + abseil to build from source instead of
              using the binary distribution, whose dynamic-framework wrapper
              fails to link absl symbols in the test bundle.
              See firebase-ios-sdk#14464 and CLAUDE.md "Running Tests". -->
         <EnvironmentVariable
            key = "FIREBASE_SOURCE_FIRESTORE"
            value = "1"
            isEnabled = "YES">
         </EnvironmentVariable>
      </EnvironmentVariables>
